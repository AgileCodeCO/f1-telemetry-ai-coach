{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Udp": {
    "Port": 20777,
    "BufferSize": 4096
  },
  "InfluxDb": {
    "Url": "http://localhost:8086",
    "Token": "my-local-token",
    "Org": "f1telemetry",
    "Bucket": "telemetry"
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=./data/f1.db"
  },
  "LLM": {
    "Provider": "ollama",
    "Model": "llama3.2",
    "BaseUrl": "http://localhost:11434",
    "TimeoutSeconds": 30
  },
  "Storage": {
    "ArchivePath": "~/f1telemetry/sessions",
    "ReplayMode": false
  }
}
